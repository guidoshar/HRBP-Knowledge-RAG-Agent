【命令 9】🚢 查询从上海发往欧洲的货物（JSONB 查询示例）
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PGPASSWORD=postgres123 psql -h 121.43.124.134 -p 5432 -U logistics -d logistics -c "
SELECT 
  o.order_number,
  o.supplier_name,
  od.payload->>'pol' AS origin_port,
  od.payload->>'pod' AS destination_port,
  od.payload->>'destination_country' AS destination_country
FROM orders o
JOIN order_details od ON o.id = od.order_id
WHERE od.tab_name = 'Location'
  AND (od.payload->>'pol' ILIKE '%Shanghai%' OR od.payload->>'pol' ILIKE '%Shenzhen%')
  AND od.payload->>'destination_country' IN ('UK', 'Germany', 'France', 'Netherlands')
ORDER BY o.order_number
LIMIT 20;
"


【命令 10】⚠️ 风险订单识别（HOD已过且进度<50%）
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PGPASSWORD=postgres123 psql -h 121.43.124.134 -p 5432 -U logistics -d logistics -c "
SELECT 
  order_number,
  supplier_name,
  process_percent,
  hod_date,
  CURRENT_DATE - hod_date AS days_overdue
FROM orders
WHERE hod_date < CURRENT_DATE 
  AND process_percent < 50
ORDER BY hod_date
LIMIT 20;
"


