【命令 7】📈 整体订单进度分布（全局统计）
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PGPASSWORD=postgres123 psql -h 121.43.124.134 -p 5432 -U logistics -d logistics -c "
SELECT 
  CASE 
    WHEN process_percent < 30 THEN '低进度(<30%)'
    WHEN process_percent BETWEEN 30 AND 80 THEN '中等进度(30-80%)'
    ELSE '高进度(>80%)'
  END AS progress_range,
  COUNT(*) AS order_count,
  ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM orders), 2) AS percentage
FROM orders
GROUP BY 
  CASE 
    WHEN process_percent < 30 THEN '低进度(<30%)'
    WHEN process_percent BETWEEN 30 AND 80 THEN '中等进度(30-80%)'
    ELSE '高进度(>80%)'
  END
ORDER BY order_count DESC;
"


